{
    "command": "mount_binded",
    "workdir": "/tmp/vitellus_work",
    "mounts": [
        {
            "source": "/dev",
            "target": "dev"
        },
        {
            "source": "/proc",
            "target": "proc"
        },
        {
            "source": "/sys",
            "target": "sys"
        },
        {
            "source": "/run",
            "target": "run"
        }
    ]
}